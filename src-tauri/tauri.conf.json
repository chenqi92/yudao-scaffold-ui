{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yudao-scaffold",
  "version": "0.1.0",
  "identifier": "cn.iocoder.yudao.scaffold",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "yudao-scaffold",
        "width": 1100,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Scaffold yudao-based Spring Boot / Cloud projects",
    "longDescription": "Interactive desktop generator for yudao monolith and microservice projects. Picks modules, frontends, prunes templates, renames packages, and writes a ready-to-build project.",
    "icon": [
      "icons/icon.png"
    ]
  }
}
